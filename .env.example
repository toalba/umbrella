# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# === Game data: pick ONE of the two options below ===

# Option 1: Pre-extracted data directory (recommended for servers)
# Extract game data locally with the upstream minimap-renderer, then upload to server.
# See README for extraction instructions.
WOWS_DATA_DIR=/path/to/extracted_data

# Option 2: Full WoWS game installation (for local development)
# WOWS_GAME_DIR=/path/to/World_of_Warships
# WOWS_GAME_VERSION=0,13,12,1,8765432

# Optional: log level
# RUST_LOG=info
